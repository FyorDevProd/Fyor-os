{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the FYOR AI SERVER OS",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "developer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Server": {
      "title": "Server",
      "description": "A managed VPS server",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ip": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline", "maintenance"] },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "ip", "status", "ownerId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "servers/{serverId}": {
      "schema": { "$ref": "#/entities/Server" },
      "description": "Managed servers"
    }
  }
}
